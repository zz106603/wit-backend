SPRING_PROFILES_ACTIVE=local

MYSQL_PORT=3306
MYSQL_DATABASE=wit
MYSQL_USER=wit
MYSQL_PASSWORD=wit
MYSQL_ROOT_PASSWORD=root

REDIS_PORT=6379

CURRENT_LOCATION_NORMALIZED_QUERY=current
CURRENT_LOCATION_DISPLAY_LOCATION=서울특별시 강남구
CURRENT_LOCATION_LAT=37.5172
CURRENT_LOCATION_LNG=127.0473

LOCATION_CACHE_TTL=24h
WEATHER_CACHE_TTL=1h
RECOMMENDATION_CACHE_TTL=30m

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/integrations/google/callback
GOOGLE_SCOPE=openid https://www.googleapis.com/auth/userinfo.email https://www.googleapis.com/auth/userinfo.profile https://www.googleapis.com/auth/calendar.readonly
GOOGLE_AUTHORIZATION_BASE_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_USER_INFO_URL=https://www.googleapis.com/oauth2/v3/userinfo
GOOGLE_OAUTH_STATE=wit-google-state
GOOGLE_ACCESS_TOKEN_EXPIRY=1h
GOOGLE_CALENDAR_BASE_URL=https://www.googleapis.com
GOOGLE_CALENDAR_EVENTS_PATH=/calendar/v3/calendars/primary/events
GOOGLE_CALENDAR_TIME_ZONE=Asia/Seoul

GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_BASE_URL=https://places.googleapis.com
GOOGLE_PLACES_TEXT_SEARCH_PATH=/v1/places:searchText
GOOGLE_PLACES_LANGUAGE_CODE=ko
GOOGLE_PLACES_REGION_CODE=KR
GOOGLE_PLACES_PAGE_SIZE=1
GOOGLE_PLACES_FIELD_MASK=places.id,places.displayName,places.formattedAddress,places.location

WEATHER_API_PROVIDER=open-meteo
OPEN_METEO_BASE_URL=https://api.open-meteo.com
OPEN_METEO_FORECAST_PATH=/v1/forecast
OPEN_METEO_TIME_ZONE=Asia/Seoul
OPEN_METEO_CURRENT_FIELDS=temperature_2m,apparent_temperature,precipitation,rain,weather_code
OPEN_METEO_HOURLY_FIELDS=temperature_2m,apparent_temperature,precipitation_probability,precipitation,rain,weather_code

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=
GEMINI_GENERATE_CONTENT_PATH=/v1beta/models/{model}:generateContent
GEMINI_CONNECT_TIMEOUT=3s
GEMINI_READ_TIMEOUT=10s
